# ===== 네이버 검색 API =====
# https://developers.naver.com/apps/ 에서 발급
NAVER_CLIENT_ID=여기에_네이버_클라이언트_아이디
NAVER_CLIENT_SECRET=여기에_네이버_클라이언트_시크릿

# ===== Anthropic Claude API =====
# https://console.anthropic.com/
ANTHROPIC_API_KEY=여기에_Anthropic_API_키

# ===== X (Twitter) API v2 — OAuth 1.0a =====
# developer.twitter.com → Project → App → Keys and Tokens
# Read + Write 권한 필요
X_API_KEY=여기에_Consumer_Key
X_API_SECRET=여기에_Consumer_Secret
X_ACCESS_TOKEN=여기에_Access_Token
X_ACCESS_TOKEN_SECRET=여기에_Access_Token_Secret

# ===== 선택 설정 =====
LOG_LEVEL=INFO